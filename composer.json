{
  "name": "vk-publisher/vk-publisher",
  "description": "Production-ready PHP client library for VK API publishing workflows",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.9",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^1.12",
    "friendsofphp/php-cs-fixer": "^3.67"
  },
  "autoload": {
    "psr-4": {
      "VkPublisher\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "VkPublisher\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --testdox",
    "stan": "phpstan analyse --memory-limit=512M",
    "cs:check": "php-cs-fixer fix --dry-run --diff",
    "cs:fix": "php-cs-fixer fix"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
