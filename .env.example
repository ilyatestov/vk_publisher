# ============================================
# VK API CONFIGURATION (NEW NESTED FORMAT)
# ============================================
VK__ACCESS_TOKEN=                    # Токен сообщества (получить в https://dev.vk.com/)
VK__GROUP_ID=                        # ID группы куда публиковать (без @, положительное число)
VK__API_VERSION=5.199                # Версия API
VK__RATE_LIMIT_PER_SECOND=3.0        # Лимит запросов в секунду
VK__PROXY_LIST=[]                    # Список прокси через запятую: ["http://proxy1:port","http://proxy2:port"]

# ============================================
# TELEGRAM BOT FOR MODERATION (NEW FORMAT)
# ============================================
TELEGRAM__TOKEN=                     # Токен бота от @BotFather
TELEGRAM__MODERATOR_CHAT_ID=         # Ваш Telegram ID (узнать у @userinfobot)

# ============================================
# AI/LLM SETTINGS (OLLAMA)
# ============================================
OLLAMA__BASE_URL=http://localhost:11434  # URL Ollama (локально или внешний)
OLLAMA__MODEL_NAME=llama2                # Модель для рерайта (llama2, mistral, qwen2.5:1.5b)
OLLAMA__TIMEOUT=60                       # Таймаут запроса в секундах
OLLAMA__MAX_TOKENS=1000                  # Максимальное количество токенов

# ============================================
# DATABASE SETTINGS
# ============================================
DATABASE__URL=sqlite+aiosqlite:///./data/vk_publisher.db  # SQLite для dev
# DATABASE__URL=postgresql+asyncpg://user:pass@host:5432/dbname  # PostgreSQL для prod
DATABASE__ECHO=false               # Логирование SQL запросов (true для отладки)

# ============================================
# SCHEDULER SETTINGS
# ============================================
SCHEDULER__CHECK_INTERVAL=60       # Интервал проверки задач (секунды)
SCHEDULER__MAX_DAILY_POSTS=50      # Лимит публикаций в день
SCHEDULER__POST_INTERVAL_MINUTES=60  # Интервал между постами (минуты)

# ============================================
# SECURITY SETTINGS
# ============================================
SECURITY__ENCRYPTION_KEY=          # 32-символьный ключ для шифрования токенов
                                   # Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECURITY__MASK_SENSITIVE_DATA=true # Маскировать токены в логах

# ============================================
# LOGGING SETTINGS
# ============================================
LOGGING__LEVEL=INFO                # DEBUG/INFO/WARNING/ERROR
LOGGING__FILE=logs/app.log         # Путь к файлу логов
LOGGING__ROTATION=10 MB            # Ротация по размеру
LOGGING__RETENTION=7 days          # Хранение логов

# ============================================
# APPLICATION SETTINGS
# ============================================
APP__HOST=0.0.0.0                  # Хост для запуска FastAPI приложения
APP__PORT=8000                     # Порт для запуска FastAPI приложения

# ============================================
# LEGACY FORMAT SUPPORT (для обратной совместимости)
# ============================================
# VK_ACCESS_TOKEN=                 # Старый формат (будет конвертирован)
# VK_GROUP_ID=                     # Старый формат
# VK_API_VERSION=5.131             # Старый формат
# TELEGRAM_BOT_TOKEN=              # Старый формат
# ADMIN_TELEGRAM_ID=               # Старый формат
# OLLAMA_BASE_URL=                 # Старый формат
# LLM_MODEL=                       # Старый формат
# DATABASE_PATH=./data/posts.db    # Старый формат
# MAX_POSTS_PER_DAY=10             # Старый формат
# LOG_LEVEL=INFO                   # Старый формат
# LOG_FILE=logs/app.log            # Старый формат
