# VK Publisher Environment Variables
# Скопируйте этот файл в .env и заполните своими значениями

# ============================================
# VK API Settings
# ============================================
VK_ACCESS_TOKEN=your_vk_access_token_here
VK_GROUP_ID=123456789
VK_API_VERSION=5.199
# PROXY_LIST=http://proxy1:8080,http://proxy2:8080

# ============================================
# Telegram Bot Settings
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_ID=123456789

# ============================================
# Ollama (AI) Settings
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2

# ============================================
# Database Settings
# ============================================
DATABASE_PATH=./data/vk_publisher.db
POSTGRES_PASSWORD=change_this_secure_password

# ============================================
# Redis Settings
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================
# Scheduler Settings
# ============================================
MAX_POSTS_PER_DAY=50

# ============================================
# Logging Settings
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================
# Security Settings
# ============================================
ENCRYPTION_KEY=generate_random_32_character_secret_key_here
