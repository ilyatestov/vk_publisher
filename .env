# ============================================
# VK API CONFIGURATION
# ============================================
VK_ACCESS_TOKEN=                    # Токен сообщества (получить в https://dev.vk.com/)
VK_GROUP_ID=                        # ID группы куда публиковать (без @)
VK_API_VERSION=5.131                # Версия API (не менять без необходимости)

# ============================================
# TELEGRAM BOT FOR MODERATION
# ============================================
TELEGRAM_BOT_TOKEN=                 # Токен бота от @BotFather
ADMIN_TELEGRAM_ID=                  # Ваш Telegram ID (узнать у @userinfobot)
ENABLE_PREVIEW=true                 # true/false — требовать подтверждение перед публикацией

# ============================================
# AI/LLM SETTINGS
# ============================================
OLLAMA_BASE_URL=http://ollama:11434 # URL Ollama (локально или внешний)
LLM_MODEL=qwen2.5:1.5b              # Модель для рерайта (должна быть установлена в Ollama)
AI_TEMPERATURE=0.7                  # Креативность (0.3-0.9)
ENABLE_AI_REWRITE=true              # true/false — использовать ИИ-рерайт

# ============================================
# CONTENT SOURCES
# ============================================
RSS_FEEDS=                          # Список RSS через запятую
VK_SEARCH_QUERIES=                  # Поисковые запросы для VK newsfeed
WEBSITE_PARSERS=                    # JSON файл с парсерами сайтов

# ============================================
# POSTING SETTINGS
# ============================================
POST_INTERVAL_MINUTES=60            # Интервал между проверками
MAX_POSTS_PER_DAY=10                # Лимит публикаций в день
ENABLE_FOOTER=true                  # Добавлять футер с ссылками
DUPLICATE_CHECK_DAYS=30             # Период проверки дубликатов (дни)

# ============================================
# PROXY SETTINGS (для парсинга)
# ============================================
ENABLE_PROXY=false                  # true/false — использовать прокси
PROXY_LIST=                         # Список прокси через запятую (если включено)

# ============================================
# LOGGING & DATABASE
# ============================================
LOG_LEVEL=INFO                      # DEBUG/INFO/WARNING/ERROR
DATABASE_PATH=./data/posts.db       # Путь к SQLite базе
BACKUP_ENABLED=true                 # Резервное копирование БД
BACKUP_INTERVAL_HOURS=24            # Интервал бэкапа

# ============================================
# DEPLOYMENT
# ============================================
ENVIRONMENT=production              # development/production
DEBUG_MODE=false                    # true только для отладки
